# Telegram (my.telegram.org dan olinadi)
API_ID=
API_HASH=
# npm run login orqali generatsiya qilinadi
SESSION=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Postgres
DATABASE_URL=postgres://user:password@localhost:5432/leedtopsmm

# Ban-avoidance / rate limit
MAX_REQUESTS_PER_HOUR=250
REQUEST_DELAY_MS=3000
REQUEST_DELAY_JITTER_MS=1500
DISCOVERY_DEPTH=2

# API
PORT=4000
# Production'da dashboard domenini ko'rsating (masalan https://leads.topsmm.uz).
# Bo'sh qoldirilsa hammaga ochiq ("*") bo'ladi — faqat lokal/dev uchun xavfsiz.
CORS_ORIGIN=*
