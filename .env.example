# Telegram (my.telegram.org dan olinadi)
API_ID=
API_HASH=
# npm run login orqali generatsiya qilinadi
SESSION=

# Gemini
GEMINI_API_KEY=
# GA (barqaror) model tavsiya etiladi — "-preview" bilan tugaydigan modellar
# ogohlantirishsiz to'xtatilishi mumkin. To'liq ro'yxat: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-3.5-flash

# Postgres
DATABASE_URL=postgres://user:password@localhost:5432/leedtopsmm
# PGSSL=true kerak bo'lsa (masalan Neon/Supabase) SSL yoqiladi. Sertifikat
# tekshiruvi standart holatda YOQILGAN (xavfsiz) — faqat provayderingiz
# o'zi imzolagan sertifikat ishlatsa va boshqa yechim bo'lmasa, bilib turib
# "false" qo'ying (bu MITM xavfini oshiradi, ehtiyot bo'ling).
# PGSSL_REJECT_UNAUTHORIZED=true

# Ban-avoidance / rate limit
MAX_REQUESTS_PER_HOUR=250
MAX_REQUESTS_PER_DAY=2000
REQUEST_DELAY_MS=3000
REQUEST_DELAY_JITTER_MS=1500
DISCOVERY_DEPTH=2

# Qora ro'yxat keshi muddati (ms) — ixtiyoriy, standart 60000
# BLACKLIST_CACHE_TTL_MS=60000

# API
PORT=4000
# Production'da dashboard domenini ko'rsating (masalan https://leads.topsmm.uz).
# Bo'sh qoldirilsa hammaga ochiq ("*") bo'ladi — faqat lokal/dev uchun xavfsiz.
CORS_ORIGIN=*
