{
  "name": "leedtopsmm",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram admin lead yig'uvchi tizim + dashboard (TopSMM.uz)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/api/server.js",
    "login": "node src/telegram/login.js",
    "migrate": "node src/db/migrate.js",
    "backfill:bot": "node src/db/backfillContactIsBot.js",
    "pipeline": "node src/jobs/runPipeline.js",
    "api": "node src/api/server.js",
    "api:dev": "node --watch src/api/server.js",
    "web": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "dev": "node scripts/dev.js",
    "test": "vitest run",
    "postinstall": "npm --prefix web install"
  },
  "dependencies": {
    "@google/genai": "^2.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "input": "^1.0.1",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "telegram": "^2.22.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vitest": "^2.1.9"
  }
}
